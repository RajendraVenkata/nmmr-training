# ============================================================
# App
# ============================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="NMMR Training Platform"

# ============================================================
# Authentication (NextAuth.js)
# ============================================================
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# Set to "true" to restrict login to admin users only (blocks learner sign-in & registration)
ENABLE_ADMIN_ONLY=false

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================
# Database (MongoDB)
# ============================================================
# MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/nmmr-training
# Local: mongodb://localhost:27017/nmmr-training
DATABASE_URL=mongodb+srv://user:password@cluster.mongodb.net/nmmr-training

# ============================================================
# Azure Blob Storage (Course content uploads)
# ============================================================
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER=training-content

# ============================================================
# Analytics (Microsoft Clarity)
# ============================================================
NEXT_PUBLIC_CLARITY_ID=your-microsoft-clarity-id

# ============================================================
# Contact Form (Formspree)
# ============================================================
FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# ============================================================
# AI Chat Widget
# ============================================================
NEXT_PUBLIC_CHAT_ENABLED=false
NEXT_PUBLIC_CHAT_API_URL=https://your-nmmr-api.azurewebsites.net/api

# ============================================================
# Email (Resend — for password reset emails)
# ============================================================
RESEND_API_KEY=re_4djbabWd_J3ZQrq8iVj8eveAcqQDcPsaa
EMAIL_FROM=noreply@nmmr.tech

# ============================================================
# Payment (Optional — uncomment when enabling)
# ============================================================
# NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret
